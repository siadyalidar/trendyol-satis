# Bu dosyayı ".env" olarak kopyalayıp kendi bilgilerinizle doldurun.
# API bilgilerini Trendyol Satıcı Panelinden alabilirsiniz:
# https://partner.trendyol.com/account/info?tab=integrationInformation
# (Sadece "master user" / admin rolüyle görünür)

TRENDYOL_SUPPLIER_ID=123456
TRENDYOL_API_KEY=buraya_api_key
TRENDYOL_API_SECRET=buraya_api_secret

# PROD (gerçek mağaza verisi) veya STAGE (test ortamı)
TRENDYOL_ENV=PROD

# Eğer bir entegrasyon firması kullanmıyorsanız SelfIntegration bırakın.
# Trendyol, User-Agent header'ında bu bilgiyi zorunlu tutuyor.
TRENDYOL_INTEGRATOR_NAME=SelfIntegration
